set_console_signature()

# Kullanıcıdan klasör iste
user_input = input("PDF'lerin oldugu klasor yolunu girin (Mevcut klasor icin Enter): \n").strip()
INPUT_DIR = user_input if user_input else "." 

OUTPUT_EXCEL = "kgd_values_number.xlsx"

def extract_values_from_pdf(pdf_path: str):
    """
    'Known Good Die' başlığını bulur.
    Hemen altındaki satırlara bakar.
    Satırda EN AZ 2 sayı varsa, İKİNCİSİNİ alır.
    """
    values = []
    
    try:
        with pdfplumber.open(pdf_path) as pdf:
            for page_idx, page in enumerate(pdf.pages, start=1):
                text = page.extract_text() or ""
                lines = text.splitlines()
                
                # Satır satır gez
                for i, line in enumerate(lines):
                    # "Known Good Die" başlığını yakala
                    if "known good die" in line.lower():
                        
                        found_target = False
                        
                        # Başlığın altındaki 3 satırı kontrol et (boşluk varsa atlasın diye)
                        for j in range(1, 4): 
                            if i + j >= len(lines): 
                                break
                                
                            next_line = lines[i + j].strip()
                            
                            # Boş satırsa geç
                            if not next_line:
                                continue
                            
                            # --- MANTIK DEĞİŞİKLİĞİ BURADA ---
                            # Satırdaki TÜM sayıları liste olarak bulur. 
                            # Örn: "Bin 1 Qty 2500" -> ['1', '2500']
                            all_numbers = re.findall(r"(\d+)", next_line)
                            
                            # Eğer satırda en az 2 sayı varsa, ikincisini al
                            if len(all_numbers) >= 2:
                                val = int(all_numbers[1]) # [0] ilk sayı, [1] ikinci sayı
                                values.append((val, page_idx, f"Satir: {next_line} -> Secilen: {val}"))
                                found_target = True
                                break # Bulduk, döngüden çık
                            else:
                                # Satırda sadece 1 sayı varsa (veya hiç yoksa) burası çalışır.
                                # "İlk sayıyı değil ikinciyi al" dediğiniz için, tek sayı varsa pas geçiyoruz.
                                pass
                        
                        # Eğer alt satırlarda bulamadıysa log basılabilir (opsiyonel)
                        if not found_target:
                            pass 

    except Exception as e:
        print(f"[HATA] Dosya okunamadi {pdf_path}: {e}")
        
    return values

def main():
    all_records = []

    if not os.path.exists(INPUT_DIR):
        print(f"[UYARI] '{INPUT_DIR}' klasörü bulunamadi.")
        return

    pdf_files = [f for f in os.listdir(INPUT_DIR) if f.lower().endswith(".pdf")]
    
    if not pdf_files:
        print(f"[UYARI] '{INPUT_DIR}' klasöründe PDF bulunamadı.")
        return

    print(f"[BILGI] {len(pdf_files)} adet PDF bulundu. İsleniyor...")

    for fname in pdf_files:
        pdf_path = os.path.join(INPUT_DIR, fname)
        print(f"[ISLENIYOR] {fname}")
        
        vals = extract_values_from_pdf(pdf_path)
        
        for val, page_idx, context in vals:
            all_records.append({
                "file": fname,
                "page": page_idx,
                "kgd_value": val,
                "context": context
            })

    if not all_records:
        print("[UYARI] Uygun formatta (Known Good Die altinda en az 2 sayi olan) veri bulunamadı.")
        return

    # DataFrame ve Excel
    df = pd.DataFrame(all_records)
    try:
        df.to_excel(OUTPUT_EXCEL, index=False)
        print(f"[OK] Excel kaydedildi -> {OUTPUT_EXCEL}")
    except Exception as e:
        print(f"[HATA] Excel kaydedilemedi: {e}")
        return

    # İstatistik ve Grafik
    vals = df["kgd_value"].to_numpy()

    if len(vals) == 0:
        return

    mean = float(np.mean(vals))
    std = float(np.std(vals, ddof=0))
    min_val, max_val = np.min(vals), np.max(vals)

    print(f"\n=== ISTATISTIKLER ===")
    print(f"Veri Sayisi       : {len(vals)}")
    print(f"Ortalama (Mean)   : {mean:.2f}")
    print(f"Standart Sapma    : {std:.2f}")
    print(f"Aralik (Min-Max)  : {min_val} - {max_val}")

    # Grafik Çizimi
    plt.figure(figsize=(10, 6))
    plt.title(f"Known-Good-Die Value Distribution n={len(vals)}")
    plt.xlabel("Value")
    plt.ylabel("Frequency")

    plt.hist(vals, bins="auto", density=True, alpha=0.7, color='purple', edgecolor='black')

    if std > 0:
        x = np.linspace(min_val, max_val, 200)
        p = (1 / (std * np.sqrt(2 * np.pi))) * np.exp(-0.5 * ((x - mean) / std) ** 2)
        plt.plot(x, p, 'k--', linewidth=2, label='Normal Dist.')
        plt.legend()

    plt.tight_layout()
    plt.show()

if __name__ == "__main__":
    main()
